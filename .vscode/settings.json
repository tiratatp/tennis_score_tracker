{
  "[kotlin]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "files.associations": {
    "*.kt": "kotlin",
    "*.kts": "kotlin"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.gradle": true,
    "**/build": true,
    "**/.kotlin": true
  },
  "search.exclude": {
    "**/.gradle": true,
    "**/build": true,
    "**/.kotlin": true
  }
}
